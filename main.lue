local Tabs = {}
local TabButtons = {}

local function createTab(name, yPos)
    local btn = Instance.new("TextButton", Sidebar)
    btn.Size = UDim2.new(0.85, 0, 0, 32)
    btn.Position = UDim2.new(0.075, 0, 0, yPos)
    btn.Text = "   " .. name
    btn.Font = Enum.Font.GothamSemibold
    btn.TextColor3 = Color3.fromRGB(160, 160, 160)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.TextSize = 12
    btn.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
    btn.BackgroundTransparency = 1
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local page = Instance.new("ScrollingFrame", TabContainer)
    page.Size = UDim2.new(1, -30, 1, -60)
    page.Position = UDim2.new(0, 18, 0, 45)
    page.BackgroundTransparency = 1
    page.ScrollBarThickness = 0
    page.Visible = false
    
    local layout = Instance.new("UIListLayout", page)
    layout.Padding = UDim.new(0, 10)
    
    table.insert(Tabs, page)
    table.insert(TabButtons, btn)
    
    btn.MouseButton1Click:Connect(function()
        for i, t in pairs(Tabs) do 
            t.Visible = false 
            tween(TabButtons[i], {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(160, 160, 160)}, 0.2) 
        end
        page.Visible = true
        TopTitle.Text = name
        tween(btn, {BackgroundTransparency = 0, TextColor3 = Color3.new(1, 1, 1)}, 0.2)
    end)
    return page
end

local MainTab = createTab("Main", 85)
local VisualsTab = createTab("Visuals", 125)

MainTab.Visible = true
tween(TabButtons[1], {BackgroundTransparency = 0, TextColor3 = Color3.new(1, 1, 1)}, 0)

-- === ЭЛЕМЕНТЫ УПРАВЛЕНИЯ (СВИТЧИ И СЛАЙДЕРЫ) ===

local function createToggle(parent, text, callback)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(0.95, 0, 0, 40)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", frame).Color = Color3.fromRGB(28, 28, 30)
    
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextSize = 13
    
    local switchBg = Instance.new("TextButton", frame)
    switchBg.Size = UDim2.new(0, 38, 0, 22)
    switchBg.Position = UDim2.new(1, -50, 0.5, -11)
    switchBg.Text = ""
    switchBg.BackgroundColor3 = Color3.fromRGB(32, 32, 35)
    Instance.new("UICorner", switchBg).CornerRadius = UDim.new(1, 0)
    
    local switchDot = Instance.new("Frame", switchBg)
    switchDot.Size = UDim2.new(0, 18, 0, 18)
    switchDot.Position = UDim2.new(0, 2, 0.5, -9)
    switchDot.BackgroundColor3 = Color3.fromRGB(160, 160, 160)
    Instance.new("UICorner", switchDot).CornerRadius = UDim.new(1, 0)
    
    local toggled = false
    switchBg.MouseButton1Click:Connect(function()
        toggled = not toggled
        if toggled then
            tween(switchDot, {Position = UDim2.new(1, -20, 0.5, -9), BackgroundColor3 = Color3.new(1, 1, 1)})
            tween(switchBg, {BackgroundColor3 = Color3.fromRGB(70, 70, 85)})
        else
            tween(switchDot, {Position = UDim2.new(0, 2, 0.5, -9), BackgroundColor3 = Color3.fromRGB(160, 160, 160)})
            tween(switchBg, {BackgroundColor3 = Color3.fromRGB(32, 32, 35)})
        end
        pcall(callback, toggled)
    end)
end

local function createSlider(parent, text, min, max, default, callback)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(0.95, 0, 0, 52)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", frame).Color = Color3.fromRGB(28, 28, 30)
    
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -20, 0, 28)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(230, 230, 230)
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextSize = 13
    
    local valLabel = Instance.new("TextLabel", frame)
    valLabel.Size = UDim2.new(0, 50, 0, 28)
    valLabel.Position = UDim2.new(1, -62, 0, 0)
    valLabel.BackgroundTransparency = 1
    valLabel.Text = tostring(default)
    valLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    valLabel.Font = Enum.Font.GothamSemibold
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.TextSize = 13

    local slideBg = Instance.new("TextButton", frame)
    slideBg.Size = UDim2.new(1, -24, 0, 6)
    slideBg.Position = UDim2.new(0, 12, 0, 34)
    slideBg.Text = ""
    slideBg.BackgroundColor3 = Color3.fromRGB(35, 35, 38)
    Instance.new("UICorner", slideBg).CornerRadius = UDim.new(1, 0)
    
    local slideFill = Instance.new("Frame", slideBg)
    local startPct = (default - min) / (max - min)
    slideFill.Size = UDim2.new(startPct, 0, 1, 0)
    slideFill.BackgroundColor3 = Color3.fromRGB(140, 140, 155)
    Instance.new("UICorner", slideFill).CornerRadius = UDim.new(1, 0)

    local dragging = false
    local function update(input)
        local pos = math.clamp((input.Position.X - slideBg.AbsolutePosition.X) / slideBg.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + ((max - min) * pos))
        slideFill.Size = UDim2.new(pos, 0, 1, 0)
        valLabel.Text = tostring(val)
        pcall(callback, val)
    end
    
    slideBg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true; update(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i) end end)
end

-- === АКТИВАЦИЯ ФУНКЦИЙ ЧИТА ===

-- УМНЫЙ МОБИЛЬНЫЙ ПОЛЕТ (Через камеру и джойстик)
local flyLoop
local flySpeed = 50

createToggle(MainTab, "Полет (Mobile Fly)", function(state)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    
    if state then
        local bv = Instance.new("BodyVelocity", hrp)
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = Vector3.new(0, 0, 0)
        
        local bg = Instance.new("BodyGyro", hrp)
        bg.Name = "FlyBG"
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.P = 9e4
        
        flyLoop = RunService.RenderStepped:Connect(function()
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                local moveDir = hum.MoveDirection
                if moveDir.Magnitude > 0 then
                    -- Двигаемся туда, куда повернута камера
                    bv.Velocity = Camera.CFrame.LookVector * flySpeed
                else
                    bv.Velocity = Vector3.new(0, 0, 0)
                end
                bg.CFrame = Camera.CFrame
            end
        end)
    else
        if flyLoop then flyLoop:Disconnect() end
        if hrp:FindFirstChild("FlyBV") then hrp.FlyBV:Destroy() end
        if hrp:FindFirstChild("FlyBG") then hrp.FlyBG:Destroy() end
    end
end)

-- НАСТРОЙКА СКОРОСТИ ПОЛЕТА
createSlider(MainTab, "Скорость полета", 20, 150, 50, function(val)
    flySpeed = val
end)

-- НАСТРОЙКА СКОРОСТИ БЕГА
createSlider(MainTab, "Скорость бега (WalkSpeed)", 16, 150, 16, function(val)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = val
    end
end)

-- СЛАЙДЕР РАСТЯГА ЭКРАНА (FOV)
createSlider(VisualsTab, "Растяг экрана (Field of View)", 70, 120, 70, function(val)
    Camera.FieldOfView = val
end)

-- ГРАФИКА
createToggle(VisualsTab, "Ультра Графика (Bloom)", function(state)
    for _, v in pairs(Lighting:GetChildren()) do if v:IsA("PostEffect") then v:Destroy() end end
    if state then
        local b = Instance.new("BloomEffect", Lighting)
        b.Intensity = 1.5
    end
end)

-- === СИСТЕМНОЕ УПРАВЛЕНИЕ ОКНОМ ===
-- Перетаскивание (Мышь и Тачпад)
local drag, dragStart, startPos
Main.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = true; dragStart = i.Position; startPos = Main.Position end end)
UserInputService.InputChanged:Connect(function(i) if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then local delta = i.Position - dragStart; Main.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = false end end)

-- Переключатель видимости
local function toggleMenu()
    Main.Visible = not Main.Visible
    if Main.Visible then
        Main.Size = UDim2.new(0, 440, 0, 280)
        tween(Main, {Size = UDim2.new(0, 500, 0, 320)}, 0.3)
    end
end

MobileBtn.MouseButton1Click:Connect(toggleMenu)
UserInputService.InputBegan:Connect(function(i, gp) if not gp and i.KeyCode == Enum.KeyCode.LeftAlt then toggleMenu() end end)
