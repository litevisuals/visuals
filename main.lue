local CheckBtn = Instance.new("TextButton", AuthFrame)
CheckBtn.Size = UDim2.new(0.85, 0, 0, 35)
CheckBtn.Position = UDim2.new(0.075, 0, 0.65, 0)
CheckBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
CheckBtn.Text = "Проверить ключ"
CheckBtn.TextColor3 = Color3.new(1, 1, 1)
CheckBtn.Font = Enum.Font.GothamSemibold
CheckBtn.TextSize = 13
Instance.new("UICorner", CheckBtn).CornerRadius = UDim.new(0, 6)

-- СТУЧИМСЯ К БОТУ ПРИ НАЖАТИИ
CheckBtn.MouseButton1Click:Connect(function()
    CheckBtn.Text = "Проверка..."
    local enteredKey = KeyBox.Text
    
    local success, response = pcall(function()
        return HttpService:GetAsync(SERVER_URL .. enteredKey)
    end)
    
    if success and response == "valid" then
        CheckBtn.Text = "Успешно!"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(35, 100, 35)
        task.wait(0.6)
        AuthFrame:Destroy()
        Main.Visible = true
        MobileBtn.Visible = true
        Main.Size = UDim2.new(0, 0, 0, 0)
        tween(Main, {Size = UDim2.new(0, 500, 0, 320)}, 0.4)
    else
        CheckBtn.Text = "Неверный или истекший ключ!"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(120, 35, 35)
        task.wait(1.5)
        CheckBtn.Text = "Проверить ключ"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    end
end)

